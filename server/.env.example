# ---- Database (required) ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cushy_crafts

# ---- Auth / cookies (required in prod; dev has insecure fallback) ----
JWT_SECRET=replace-with-a-long-random-string
COOKIE_SECRET=replace-with-a-long-random-string
JWT_EXPIRES=7d
# Set to "true" in production (HTTPS-only cookies).
COOKIE_SECURE=false
# Optional: set to your domain (e.g. ".aavisdecor.com") for cross-subdomain cookie sharing.
COOKIE_DOMAIN=

# ---- Server ----
PORT=3001
HOST=0.0.0.0
FRONTEND_ORIGIN=http://localhost:8080

# ---- Uploads ----
UPLOAD_DIR=./uploads/product-images
PUBLIC_MEDIA_BASE_URL=

# ---- First admin (bootstraps a single admin account on signup) ----
FIRST_ADMIN_EMAIL=

# ---- Razorpay (required for UPI / card payments) ----
# Use rzp_test_* for sandbox, rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- Shiprocket (required for fulfillment) ----
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Must match a pickup location already configured in your Shiprocket dashboard.
SHIPROCKET_PICKUP_LOCATION_NAME=Primary
# Warehouse pincode — used for courier serviceability queries.
SHIPROCKET_PICKUP_PINCODE=
# Optional package dimension defaults (applied when product lacks its own).
SHIPROCKET_DEFAULT_WEIGHT=0.5
SHIPROCKET_DEFAULT_LENGTH=30
SHIPROCKET_DEFAULT_BREADTH=20
SHIPROCKET_DEFAULT_HEIGHT=10
# Optional channel id (if you use Shiprocket channels feature).
SHIPROCKET_CHANNEL_ID=
# Optional HMAC-SHA256 secret for webhook signature verification.
# REQUIRED in production — unsigned webhooks are rejected when NODE_ENV=production.
SHIPROCKET_WEBHOOK_SECRET=
