# Production build: copy to .env.production or set in Hostinger / CI before `npm run build`.
#
# The SPA talks to your Node API (see server/VPS_RUNBOOK.md), not Firebase.

# Optional: only if the API is on another origin (e.g. https://api.yourdomain.com).
# Leave empty when Nginx serves the app and proxies /api on the same host.
# VITE_API_URL=https://api.yourdomain.com

# Legacy — not used by the current app (PostgreSQL + REST API). Remove from
# Hostinger env if you still have them; they do not enable Firebase in this build.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
